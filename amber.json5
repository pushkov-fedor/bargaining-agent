{
  manifest_version: "0.3.0",
  program: {
    image: "ghcr.io/pushkov-fedor/bargaining-agent:latest",
    network: {
      endpoints: [
        { name: "api", port: 8080, protocol: "http" }
      ]
    }
  },
  provides: {
    api: { kind: "http", endpoint: "api" }
  },
  exports: {
    api: "api"
  }
}
